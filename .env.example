# Copie este arquivo para .env e preencha com chaves reais.
# NUNCA comite o .env de verdade.

# Chave da Hiker API (https://hikerapi.com) - cada request custa ~$0.001 no Start plan
HIKER_API_KEY=coloque_sua_chave_aqui

# Chave da Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=coloque_sua_chave_aqui

# Modelo Gemini. Default: gemini-2.5-flash (rápido, free tier generoso).
# Alternativas:
#   - gemini-2.5-flash-lite (mais barato)
#   - gemini-3-flash-preview (mais novo, mas free tier muito restrito em 2026-05)
GEMINI_MODEL=gemini-2.5-flash
